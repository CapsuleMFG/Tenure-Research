# Project data — gitignored on main. The weekly GitHub Action force-pushes
# refreshed artifacts to the `data` branch (using `git add -f`), which is
# what Streamlit Cloud reads. Keeping them out of main keeps PRs reviewable.
data/raw/
data/clean/

# Streamlit run logs (local-only)
sl.log
sl_err.log

# Generated test fixtures — built fresh each test run
tests/fixtures/*.xlsx

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtualenvs
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# uv
.uv/

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# Claude Code per-project state
.claude/

# Superpowers brainstorming session artifacts
.superpowers/
