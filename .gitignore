# Project data:
# - data/raw/ stays gitignored (downloaded XLSX/CSV source files; can
#   always be re-fetched via sync_downloads + sync_*_futures).
# - data/clean/ is committed to main so Streamlit Cloud has something
#   to serve immediately. The weekly + daily Actions refresh and push
#   to main directly. Files are tiny (parquet ~30KB, forecasts ~60KB).
data/raw/

# Streamlit run logs (local-only)
sl.log
sl_err.log

# Generated test fixtures — built fresh each test run
tests/fixtures/*.xlsx

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtualenvs
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# uv
.uv/

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# Claude Code per-project state
.claude/

# Superpowers brainstorming session artifacts
.superpowers/
